# macOS
.DS_Store
.AppleDouble
.LSOverride

# Build artifacts (iCE40 flow)
*.vvp
*.vcd
*.json
*.asc
*.bin
*.blif
*.log

# Carve out CTF chain manifest from the *.json catch-all above. This file
# is the per-cohort sealing record (which exercise emits which flag) and
# is regenerated by scripts/lab_ctf/seal_all.py — instructors want it in
# version control even though it's a .json file.
!scripts/lab_ctf/chain.json

# Editor / IDE
*.swp
*.swo
*~
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Nix
result
result-*
.direnv/
.envrc.local

# Python
__pycache__/
*.pyc

# Generated build outputs
# Generated content (rebuilt by prep_mkdocs.py)
docs_src/downloads/
docs_src/barcelona/
# Custom portal output (rebuilt by build_site.py, not deployed)
site/
# MkDocs build output
_site/
